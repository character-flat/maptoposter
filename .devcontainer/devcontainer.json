{
  "name": "MapToPoster",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && export PATH=\"$HOME/.local/bin:$PATH\" && uv sync --locked",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.flake8"
      ],
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python",
        "flake8.args": ["--max-line-length=160"]
      }
    }
  }
}
